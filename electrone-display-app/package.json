{
  "name": "electrone-display-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "electron-dev": "concurrently --kill-others \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "start": "npm run build && electron .",
    "build": "vite build",
    "electron-build": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "react": "^19.2.4",
    "react-battery-gauge": "^1.0.7",
    "react-dom": "^19.2.4",
    "react-gauge-component": "^2.0.28",
    "react-thermometer": "^0.0.3",
    "react-thermometer-component": "^1.0.1",
    "react-thermometer-ecotropy": "^1.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^7.0.1"
  }
}
